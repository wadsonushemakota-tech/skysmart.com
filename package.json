{
  "name": "sky-smart-website",
  "version": "1.0.0",
  "description": "Sky Smart Fashion Website with Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "webpack --mode production",
    "vercel-build": "node scripts/write-api-config.js && webpack --mode production",
    "dev-react": "webpack --mode development --watch",
    "serve": "npm run build && npx serve dist -l 3000",
    "start-react": "npm run build && npm run serve",
    "install-all": "npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.19.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.8.3",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.0",
    "baseline-browser-mapping": "^2.10.13",
    "css-loader": "^6.8.0",
    "html-webpack-plugin": "^5.5.0",
    "nodemon": "^3.0.1",
    "style-loader": "^3.3.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "keywords": [
    "fashion",
    "ecommerce",
    "website",
    "nodejs",
    "express",
    "react"
  ],
  "author": "Sky Smart",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
