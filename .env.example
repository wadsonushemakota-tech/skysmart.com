# Server
PORT=3000
NODE_ENV=development

# PostgreSQL — local: postgres://...  |  Supabase: Project Settings → Database → Connection string (URI)
# Use the "Session" or "Direct" connection (port 5432) for this Node server, not serverless pooler unless you use pgBouncer mode.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/sky_smart

# Auth — required when NODE_ENV=production (run: node scripts/generate-secrets.js)
JWT_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=

# Split deploy (Railway API + Vercel static): comma-separated frontend origins
# Example: CORS_ORIGIN=https://your-app.vercel.app,https://www.yourdomain.com
CORS_ORIGIN=

# Public URL of the API (used for Stripe fallbacks and redirects). On Railway you can set:
# PUBLIC_URL=https://your-service.up.railway.app
# or rely on TRUST_PROXY + Host (set TRUST_PROXY=1).
PUBLIC_URL=

# Railway provides RAILWAY_PUBLIC_DOMAIN — server uses https://{RAILWAY_PUBLIC_DOMAIN} if PUBLIC_URL is unset.

# Behind reverse proxy: set to 1
TRUST_PROXY=

# Railway only: serve API + uploads only (no static HTML). Set API_ONLY=1 when the site is on Vercel.
API_ONLY=

# Force-disable DB SSL (local dev). Supabase/production URLs use SSL automatically.
DATABASE_SSL=

# Vercel build (also set in Vercel → Environment Variables): backend public URL, no trailing slash
# PUBLIC_API_URL=https://your-service.up.railway.app
